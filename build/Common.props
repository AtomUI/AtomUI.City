<Project>
  <PropertyGroup>
    <AtomUICityDevelopTargetFramework>net10.0</AtomUICityDevelopTargetFramework>
    <AtomUICityProductionTargetFramework>net8.0</AtomUICityProductionTargetFramework>
    <OutputType>Library</OutputType>
    <TrimMode>copyused</TrimMode>
    <Configuration Condition="'$(Configuration)' == ''">Debug</Configuration>
    <BuiltInComInteropSupport>false</BuiltInComInteropSupport>

    <AtomUICityTargetFrameworks Condition=" '$(Configuration)' == 'Debug' ">$(AtomUICityDevelopTargetFramework)</AtomUICityTargetFrameworks>
    <AtomUICityTargetFrameworks Condition=" '$(Configuration)' == 'Release' ">$(AtomUICityDevelopTargetFramework);$(AtomUICityProductionTargetFramework)</AtomUICityTargetFrameworks>

    <IsTestProject Condition="$(MSBuildProjectFullPath.Contains('tests')) and $(MSBuildProjectName.EndsWith('.Tests'))">true</IsTestProject>
    <IsTestProject Condition="$(MSBuildProjectFullPath.Contains('tests')) and $(MSBuildProjectName.EndsWith('SmokeTests'))">true</IsTestProject>
    <AccelerateBuildsInVisualStudio>true</AccelerateBuildsInVisualStudio>
    <NoWarn>$(NoWarn);CS1591;CS0436;CS7035;NU5104</NoWarn>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>$(AllowedOutputExtensionsInPackageBuildOutputFolder);.pdb</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <GenerateAssemblyConfigurationAttribute>true</GenerateAssemblyConfigurationAttribute>
    <GenerateAssemblyCompanyAttribute>true</GenerateAssemblyCompanyAttribute>
    <GenerateAssemblyProductAttribute>true</GenerateAssemblyProductAttribute>
    <WarningsAsErrors>Nullable</WarningsAsErrors>
  </PropertyGroup>
</Project>
